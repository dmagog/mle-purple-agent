# OpenRouter (free models available)
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use, selected via MODEL_NAME.
# The gold submission ran on the paid model google/gemini-2.5-pro.
# The uncommented line below is a FREE default for local testing — swap in
# google/gemini-2.5-pro to reproduce the gold run.
# Free options on OpenRouter:
# nvidia/llama-3.1-nemotron-ultra-253b-v1:free  — large, good at code
# nvidia/nemotron-3-super-120b-a12b:free         — fast and free
# minimax/minimax-m2.5:free                      — large context
# google/gemma-4-31b-it:free                     — Google free
MODEL_NAME=nvidia/llama-3.1-nemotron-ultra-253b-v1:free

# OpenRouter base URL (don't change)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
